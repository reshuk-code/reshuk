    <content>&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;en&quot;&gt;
&lt;head&gt;
&lt;meta charset=&quot;UTF-8&quot;&gt;
&lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;
&lt;title&gt;IT Company&lt;/title&gt;

&lt;style&gt;
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: &apos;Segoe UI&apos;, sans-serif;
}

body {
  scroll-behavior: smooth;
}

/* NAVBAR */
nav {
  position: fixed;
  width: 100%;
  padding: 15px 50px;
  display: flex;
  justify-content: space-between;
  background: rgba(0,0,0,0.7);
  color: white;
  z-index: 1000;
}

nav a {
  color: white;
  margin-left: 20px;
  text-decoration: none;
}

/* HERO */
.hero {
  height: 100vh;
  background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
  display: flex;
  justify-content: center;
  align-items: center;
  color: white;
  text-align: center;
  flex-direction: column;
}

.hero h1 {
  font-size: 50px;
  animation: fadeInDown 1s ease;
}

.hero p {
  margin: 20px 0;
  font-size: 20px;
  animation: fadeInUp 1.2s ease;
}

.hero button {
  padding: 12px 25px;
  border: none;
  background: #00c6ff;
  color: white;
  border-radius: 5px;
  cursor: pointer;
}

/* SECTIONS */
section {
  padding: 80px 50px;
  text-align: center;
}

.services, .about, .contact {
  opacity: 0;
  transform: translateY(50px);
  transition: 0.6s ease;
}

.show {
  opacity: 1;
  transform: translateY(0);
}

/* CARDS */
.cards {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 30px;
  flex-wrap: wrap;
}

.card {
  padding: 20px;
  background: #f5f5f5;
  border-radius: 10px;
  width: 250px;
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-10px);
}

/* CONTACT */
input, textarea {
  width: 300px;
  padding: 10px;
  margin: 10px;
}

button.submit {
  background: black;
  color: white;
}

/* ANIMATIONS */
@keyframes fadeInDown {
  from {opacity: 0; transform: translateY(-30px);}
  to {opacity: 1; transform: translateY(0);}
}

@keyframes fadeInUp {
  from {opacity: 0; transform: translateY(30px);}
  to {opacity: 1; transform: translateY(0);}
}

/* RESPONSIVE */
@media(max-width: 768px) {
  nav {padding: 15px;}
  .hero h1 {font-size: 30px;}
}
&lt;/style&gt;
&lt;/head&gt;

&lt;body&gt;

&lt;!-- NAVBAR --&gt;
&lt;nav&gt;
  &lt;h2&gt;TechNova&lt;/h2&gt;
  &lt;div&gt;
    &lt;a href=&quot;#home&quot;&gt;Home&lt;/a&gt;
    &lt;a href=&quot;#services&quot;&gt;Services&lt;/a&gt;
    &lt;a href=&quot;#about&quot;&gt;About&lt;/a&gt;
    &lt;a href=&quot;#contact&quot;&gt;Contact&lt;/a&gt;
  &lt;/div&gt;
&lt;/nav&gt;

&lt;!-- HERO --&gt;
&lt;section class=&quot;hero&quot; id=&quot;home&quot;&gt;
  &lt;h1&gt;We Build Future Tech&lt;/h1&gt;
  &lt;p&gt;Modern IT Solutions for Your Business&lt;/p&gt;
  &lt;button onclick=&quot;scrollToSection(&apos;services&apos;)&quot;&gt;Explore&lt;/button&gt;
&lt;/section&gt;

&lt;!-- SERVICES --&gt;
&lt;section class=&quot;services&quot; id=&quot;services&quot;&gt;
  &lt;h2&gt;Our Services&lt;/h2&gt;
  &lt;div class=&quot;cards&quot;&gt;
    &lt;div class=&quot;card&quot;&gt;Web Development&lt;/div&gt;
    &lt;div class=&quot;card&quot;&gt;Mobile Apps&lt;/div&gt;
    &lt;div class=&quot;card&quot;&gt;AI Solutions&lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;!-- ABOUT --&gt;
&lt;section class=&quot;about&quot; id=&quot;about&quot;&gt;
  &lt;h2&gt;About Us&lt;/h2&gt;
  &lt;p&gt;We are a modern IT company delivering high-quality tech solutions worldwide.&lt;/p&gt;
&lt;/section&gt;

&lt;!-- CONTACT --&gt;
&lt;section class=&quot;contact&quot; id=&quot;contact&quot;&gt;
  &lt;h2&gt;Contact Us&lt;/h2&gt;
  &lt;input type=&quot;text&quot; placeholder=&quot;Your Name&quot;&gt;&lt;br&gt;
  &lt;input type=&quot;email&quot; placeholder=&quot;Email&quot;&gt;&lt;br&gt;
  &lt;textarea placeholder=&quot;Message&quot;&gt;&lt;/textarea&gt;&lt;br&gt;
  &lt;button class=&quot;submit&quot;&gt;Send&lt;/button&gt;
&lt;/section&gt;

&lt;script&gt;
// smooth scroll
function scrollToSection(id) {
  document.getElementById(id).scrollIntoView({ behavior: &apos;smooth&apos; });
}

// scroll animation
const sections = document.querySelectorAll(&apos;.services, .about, .contact&apos;);

window.addEventListener(&apos;scroll&apos;, () =&gt; {
  const trigger = window.innerHeight * 0.8;

  sections.forEach(section =&gt; {
    const top = section.getBoundingClientRect().top;

    if (top &lt; trigger) {
      section.classList.add(&apos;show&apos;);
    }
  });
});
&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;</content>
