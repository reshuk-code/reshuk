// Prisma schema for reshuk.com.np
// Neon (Postgres) backend for auth sessions and blog posts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@map("sessions")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  cover     String   @default("")
  content   String
  published Boolean  @default(true)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("posts")
}
